# Backend environment variables
# Copy this file and fill in real values — never commit real secrets

ASPNETCORE_ENVIRONMENT=Production

# Neon PostgreSQL connection string
# Get from: Neon dashboard → your project → Connection string → Npgsql/ADO.NET format
ConnectionStrings__Default=postgresql://neondb_owner:npg_0mnbGcQRg7KN@ep-wild-darkness-a8pr4trm-pooler.eastus2.azure.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT — use a strong random string (min 32 chars) for Key
Jwt__Key=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
Jwt__Issuer=restaurant-saas
Jwt__Audience=restaurant-saas-clients

# Your Cloudflare Pages frontend URL (no trailing slash)
Frontend__BaseUrl=https://your-app.pages.dev

# Port — Render injects this automatically; only set manually if running locally in Docker
PORT=10000
